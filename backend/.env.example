# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
# SQLite (default - file-based)
DATABASE_PATH=./database.sqlite

# PostgreSQL (for production - optional)
# DATABASE_URL=postgresql://username:password@hostname:5432/wellness_db

# ============================================================
# SECURITY & JWT
# ============================================================
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app

# ============================================================
# EXTERNAL APIS
# ============================================================
OPENROUTER_API_KEY=your_openrouter_key_here

# ============================================================
# EMAIL (SMTP) FOR OTP/NOTIFICATIONS
# ============================================================
# Example Gmail SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# EMAIL_FROM=SkillSpring <your_email@gmail.com>
# OR quick OTP testing with Nodemailer Gmail service:
# (Requires enabling 2FA and creating an App Password at
#  https://myaccount.google.com/apppasswords)
# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ============================================================
# TWILIO SMS FOR OTP/NOTIFICATIONS
# ============================================================
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ============================================================
# OTP DEBUG FLAGS
# ============================================================
# Return OTP code in API response only if true (for local testing)
ALLOW_DEV_OTP_ECHO=false
# Show OTP code text in frontend prompt only if true
# (set in frontend-student/.env as REACT_APP_SHOW_DEV_OTP=true)

# ============================================================
# DEPLOYMENT PLATFORMS (optional)
# ============================================================
# For Railway.app
# RAILWAY_ENVIRONMENT_NAME=production

# For Render.com
# RENDER_SERVICE_ID=your_service_id
